// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String   @id // The slug/id (e.g. "pitaya")
  name              String
  whatsappNumber    String
  calendarId        String
  businessHours     Json     // { start, end, days }
  googleClientEmail String?
  googlePrivateKey  String?  @db.Text
  isPremiumAI       Boolean  @default(false)
  cancelationBuffer Int      @default(15)
  slotBuffer        Int      @default(0) // Minutes between appointments
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  appointments      Appointment[]
  services          Service[]
}

model Service {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  duration    Int      @default(60)
  price       Float?
  isActive    Boolean  @default(true)

  @@index([tenantId])
}

model Appointment {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  service     String
  patientName String
  googleEventId String?
  startTime   DateTime
  status        String   @default("confirmada")
  paymentStatus String   @default("pendiente") // pendiente, pagada, fallida
  amount        Float?
  reminderSent  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}
